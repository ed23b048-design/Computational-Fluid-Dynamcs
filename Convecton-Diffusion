# Implementing upwind scheme 
# (Note: Accuracy is the only thing which bother in upwind scheme due to first order accuracy )

while 1:
    if u>0 and v>0:
        T_new=T.copy()
        e=0

        for i in range(1,m+1):
            for j in range(1,n+1):
                a_E=(gamma*dy[0,i-1]/delta_x[0,j])
                a_W=(gamma*dy[0,i-1]/delta_x[0,j-1])+(rho*u*dy[0,i-1])
                a_N=(gamma*dx[0,j-1]/delta_y[0,i])
                a_S=(gamma*dx[0,j-1]/delta_y[0,i-1])+(rho*v*dx[0,j-1])
                a_P=(a_E+a_W+a_N+a_S)

                T_new[i,j]=(a_E*T[i,j+1]+a_W*T[i,j-1]+a_N*T[i+1,j]+a_S*T[i-1,j])/a_P

                e+=abs(T[i,j]*a_P-(a_E*T[i,j+1]+a_W*T[i,j-1]+a_N*T[i+1,j]+a_S*T[i-1,j]))

        print(e)

        T=T_new.copy()

        if e<tolerance:
            break        

    
    if u<0 and v<0:
        T_new=T.copy()
        e=0

        for i in range(1,m+1):
            for j in range(1,n+1):
                a_E=(gamma*dy[0,i-1]/delta_x[0,j]-(rho*u*dy[0,i-1]))
                a_W=(gamma*dy[0,i-1]/delta_x[0,j-1])
                a_N=(gamma*dx[0,j-1]/delta_y[0,i]-(rho*v*dx[0,j-1]))
                a_S=(gamma*dx[0,j-1]/delta_y[0,i-1])
                a_P=(a_E+a_W+a_N+a_S)

                T_new[i,j]=(a_E*T[i,j+1]+a_W*T[i,j-1]+a_N*T[i+1,j]+a_S*T[i-1,j])/a_P

                e+=abs(T[i,j]*a_P-(a_E*T[i,j+1]+a_W*T[i,j-1]+a_N*T[i+1,j]+a_S*T[i-1,j]))

        print(e)

        T=T_new.copy()

        if e<tolerance:
            break        

